# Airtable Configuration
# Get your API key from: https://airtable.com/create/tokens
VITE_AIRTABLE_API_KEY=your_airtable_api_key_here

# Get your Base ID from your Airtable base URL
# Format: https://airtable.com/appXXXXXXXXXXXXXX/...
VITE_AIRTABLE_BASE_ID=your_base_id_here

# Table name (default: "Survey Responses")
VITE_AIRTABLE_TABLE_NAME=Survey Responses

# Resend.com Email Configuration
# Get your API key from: https://resend.com/api-keys
VITE_RESEND_API_KEY=your_resend_api_key_here

# Email sender configuration
VITE_FROM_EMAIL=hello@aibusiness.id
VITE_FROM_NAME=AI Business Team
